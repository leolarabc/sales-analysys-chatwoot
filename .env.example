# ════════════════════════════════════════════════════════
# BoateBus Central — Variáveis de Ambiente
# Copie para .env e preencha com os valores reais
# NUNCA commite o .env no git
# ════════════════════════════════════════════════════════

# ── API BoateBus ──────────────────────────────────────────
BOATEBUS_TOKEN=Bearer YOUR_BOATEBUS_TOKEN

# ── Chatwoot ──────────────────────────────────────────────
CHATWOOT_TOKEN=YOUR_CHATWOOT_TOKEN
CHATWOOT_ACCOUNT_ID=YOUR_ACCOUNT_ID

# ── Claude API (Anthropic) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── OpenAI (Whisper — transcrição de áudios) ─────────────
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY

# ── PostgreSQL ────────────────────────────────────────────
# PG_HOST=postgres → hostname do serviço Docker na rede overlay
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=n8n_queue
PG_USER=postgres
PG_PASSWORD=YOUR_PG_PASSWORD

# ── Alertas por E-mail ────────────────────────────────────
# Gmail App Password (sem espaços): gere em myaccount.google.com/apppasswords
ALERT_EMAIL_FROM=alerts@yourcompany.com
ALERT_EMAIL_PASS=YOUR_GMAIL_APP_PASSWORD
ALERT_EMAIL_TO=admin@yourcompany.com
